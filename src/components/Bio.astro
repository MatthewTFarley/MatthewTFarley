---
import { Image } from "astro:assets";
import profilePic from "../assets/profile-pic.jpg";
---

<div class="mb-8 flex items-center gap-4">
  <Image
    src={profilePic}
    alt="Matthew T Farley"
    width={64}
    height={64}
    class="min-w-[64px] rounded-full ring-2 ring-offset-2"
    style="ring-color: var(--color-border); ring-offset-color: var(--color-bg);"
  />
  <p class="mb-0 text-[0.95rem]" style="color: var(--color-text-secondary);">
    Software engineer based in Philadelphia.
  </p>
</div>
