---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button
  class:list={[
    "inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg cursor-pointer",
    "border transition-colors duration-150",
    className,
  ]}
  style="color: var(--color-accent); border-color: var(--color-border); background: transparent;"
>
  <slot />
</button>

<style>
  button:hover {
    background-color: var(--color-code-bg);
    border-color: var(--color-accent);
  }
</style>
