---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button
  class:list={[
    "block border-none text-center box-border no-underline px-6 py-2.5 cursor-pointer uppercase tracking-widest",
    "bg-black text-white text-[15px] font-semibold rounded-md",
    "hover:shadow-[inset_0_0_100px_100px_rgba(255,255,255,0.25)]",
    className,
  ]}
>
  <slot />
</button>
