---
import { getCollection } from "astro:content";
import Layout from "../layouts/layout.astro";
import Bio from "../components/bio.astro";

const posts = (await getCollection("blog"))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);
---

<Layout
  title="Home"
  keywords={["personal", "portfolio", "blog", "astro", "javascript", "react"]}
>
  <section class="mb-16">
    <Bio />
    <h1
      class="mb-3 text-3xl font-semibold tracking-tight sm:text-4xl"
      style="letter-spacing: -0.03em;"
    >
      Matthew T Farley
    </h1>
    <p class="mb-6 text-lg" style="color: var(--color-text-secondary);">
      Software engineer in Philadelphia
    </p>
    <p style="color: var(--color-text-secondary);">
      Welcome to my corner of the internet. I write about software engineering,
      tools I find interesting, and things I'm learning along the way.
    </p>
  </section>

  {
    posts.length > 0 && (
      <section>
        <h2
          class="mb-6 text-sm font-medium tracking-wider uppercase"
          style="color: var(--color-text-tertiary); letter-spacing: 0.1em;"
        >
          Recent Posts
        </h2>
        <div class="flex flex-col gap-1">
          {posts.map((post) => {
            const date = new Date(post.data.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });
            return (
              <a
                href={`/blog/${post.id}/`}
                class="group -mx-4 block rounded-lg px-4 py-4 no-underline transition-colors"
                style="color: inherit;"
              >
                <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                  <h3 class="m-0 text-base font-medium transition-colors group-hover:text-[var(--color-accent)]">
                    {post.data.title}
                  </h3>
                  <time
                    class="shrink-0 font-mono text-xs"
                    style="color: var(--color-text-tertiary);"
                  >
                    {date}
                  </time>
                </div>
                <p
                  class="mt-1 mb-0 text-sm"
                  style="color: var(--color-text-secondary);"
                >
                  {post.data.description}
                </p>
              </a>
            );
          })}
        </div>
        <div class="mt-8">
          <a
            href="/blog/"
            class="inline-flex items-center gap-1 text-sm font-medium"
          >
            View all posts <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </section>
    )
  }
</Layout>

<style>
  a.group:hover {
    background-color: var(--color-code-bg);
  }
</style>
