---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="All posts">
  <h1 class="mb-8">All Posts</h1>
  <div class="flex flex-col">
    {posts.map((post, index) => {
      const title = post.data.title || post.id;
      const date = new Date(post.data.date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
      return (
        <>
          {index > 0 && <hr class="my-0" />}
          <a
            href={`/blog/${post.id}/`}
            class="group block no-underline rounded-lg -mx-4 px-4 py-5 transition-colors"
            style="color: inherit;"
          >
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
              <h3 class="text-base font-medium group-hover:text-[var(--color-accent)] transition-colors m-0">
                {title}
              </h3>
              <time
                class="font-mono text-xs shrink-0"
                style="color: var(--color-text-tertiary);"
              >
                {date}
              </time>
            </div>
            <p class="text-sm mt-1.5 mb-0" style="color: var(--color-text-secondary);">
              {post.data.description}
            </p>
          </a>
        </>
      );
    })}
  </div>
</Layout>

<style>
  a.group:hover {
    background-color: var(--color-code-bg);
  }
</style>
