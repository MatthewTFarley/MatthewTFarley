---
import { getCollection } from "astro:content";
import Layout from "../../layouts/layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout title="All posts">
  <h1 class="mb-8">All Posts</h1>
  <div class="flex flex-col">
    {
      posts.map((post, index) => {
        const title = post.data.title || post.id;
        const date = new Date(post.data.date).toLocaleDateString("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric",
        });
        return (
          <>
            {index > 0 && <hr class="my-0" />}
            <a
              href={`/blog/${post.id}/`}
              class="group -mx-4 block rounded-lg px-4 py-5 no-underline transition-colors"
              style="color: inherit;"
            >
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                <h3 class="m-0 text-base font-medium transition-colors group-hover:text-[var(--color-accent)]">
                  {title}
                </h3>
                <time
                  class="shrink-0 font-mono text-xs"
                  style="color: var(--color-text-tertiary);"
                >
                  {date}
                </time>
              </div>
              <p
                class="mt-1.5 mb-0 text-sm"
                style="color: var(--color-text-secondary);"
              >
                {post.data.description}
              </p>
            </a>
          </>
        );
      })
    }
  </div>
</Layout>

<style>
  a.group:hover {
    background-color: var(--color-code-bg);
  }
</style>
