---
import Layout from "../layouts/layout.astro";
---

<Layout
  title="Greeting"
  description="A personal greeting from Matt and Claude."
>
  <section class="mb-16">
    <h1
      class="mb-6 text-3xl font-semibold tracking-tight sm:text-4xl"
      style="letter-spacing: -0.03em;"
    >
      Hello Greg and Faith!
    </h1>
    <p class="text-lg" style="color: var(--color-text-secondary);">
      From Matt and Claude
    </p>
  </section>
</Layout>
