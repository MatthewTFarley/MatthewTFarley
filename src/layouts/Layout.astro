---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
}

const { title, description, keywords = [] } = Astro.props;
const siteTitle = "Matthew T Farley";
const siteDescription = "The personal website of Matthew T Farley.";
const metaDescription = description || siteDescription;

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const ogTitle = isHome ? siteTitle : `${title} | ${siteTitle}`;
const ogImage = new URL("/og-image.png", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title} | {siteTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@matthewtfarley" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <div class="mx-auto w-full max-w-3xl px-6 py-8 flex-1">
        <header class="flex items-center justify-between mb-12">
          <a
            href="/"
            class="text-lg font-semibold tracking-tight no-underline"
            style="color: var(--color-text);"
          >
            {siteTitle}
          </a>
          <nav class="flex items-center gap-6">
            <a
              href="/blog/"
              class="nav-link text-sm font-medium no-underline transition-colors"
            >
              Blog
            </a>
            <ThemeToggle />
          </nav>
        </header>
        <main>
          <slot />
        </main>
      </div>
      <footer class="text-center py-8" style="color: var(--color-text-tertiary); font-size: 0.8rem;">
        &copy; {new Date().getFullYear()} {siteTitle}
      </footer>
    </div>
  </body>
</html>

<style>
  .nav-link {
    color: var(--color-text-secondary);
  }
  .nav-link:hover {
    color: var(--color-text);
  }
</style>
