{
  "name": "matthewtfarley",
  "private": true,
  "description": "The website of Matthew T Farley",
  "version": "2.0.0",
  "author": "Matthew T Farley <matthewthomasfarley@gmail.com>",
  "type": "module",
  "bugs": {
    "url": "https://github.com/matthewtfarley/matthewtfarley/issues"
  },
  "homepage": "https://matthewtfarley.com",
  "keywords": [
    "astro"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthewtfarley/matthewtfarley.git"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "deploy:preview": "pnpm exec netlify deploy --auth \"$DEPLOY_AUTH_TOKEN\" --site \"$DEPLOY_SITE_ID\" --dir dist --no-build --context deploy-preview --json",
    "deploy:production": "pnpm exec netlify deploy --auth \"$DEPLOY_AUTH_TOKEN\" --site \"$DEPLOY_SITE_ID\" --dir dist --no-build --context production --prod --json",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "husky",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.5.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "netlify-cli": "^23.15.1",
    "oxlint": "^1.49.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec prettier --write",
      "pnpm exec oxlint --fix"
    ],
    "*.{astro,css,md,mdx,json,yml,yaml,html}": [
      "pnpm exec prettier --write"
    ]
  }
}
